{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "react": ["./src/node_modules/@types/react"],
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/components": ["./src/components/index"],
      "@/storybook/*": ["./src/utils/storybook/*"],
      "@/storybook/utils/*": ["./src/utils/storybook/*"],
      "@/types/*": ["./src/types/*"],
      "@/types": ["./src/types/index"],
      "@/ui/*": ["./src/components/ui/*"],
      "@/ui": ["./src/components/ui/index"],
      "@/utils/*": ["./src/utils/*"],
      "@/utils/storybook/*": ["./src/utils/storybook/*"],
      "@/utils": ["./src/utils/index"],
      "@/stories": ["./src/stories/index"],
      "@/stories/*": ["./src/stories/*"],
      "@/theme": ["./src/theme/index"],
      "@/theme/*": ["./src/theme/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
